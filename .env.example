# Local server endpoint
OPENENV_BASE_URL=http://localhost:8000

# Optional model-backed inference
# Leave both empty for deterministic local testing without any model API
HF_TOKEN=
API_KEY=
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct:scaleway

# Inference controls
DESIGNGYM_TASK=poster_basic_v1
DESIGNGYM_BENCHMARK=designgym
DESIGNGYM_MAX_STEPS=8
TEMPERATURE=0.0
MAX_TOKENS=24
LLM_TIMEOUT=20
SUCCESS_SCORE_THRESHOLD=0.55

# Optional: run against Docker image directly instead of base URL
LOCAL_IMAGE_NAME=